{
  "name": "wapi",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "dev": "pnpm --filter @wappy/app dev",
    "build": "tsx scripts/build.ts",
    "build:app": "pnpm --filter @wappy/app build",
    "deploy": "pnpm --filter @wappy/app deploy:cf",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --filter @wappy/app --filter @wappy/cli test",
    "wapi": "pnpm --filter @wappy/cli dev --"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
